<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Edge Content Loader Tester</title>

<style>
body {
  font-family: Arial, sans-serif;
  padding: 20px;
}

input, select {
  padding: 8px;
  margin: 5px 0;
  width: 100%;
  max-width: 500px;
}

button {
  padding: 10px 15px;
  font-size: 16px;
  cursor: pointer;
  margin-top: 10px;
  margin-right: 8px;
}

#results {
  margin-top: 15px;
  white-space: pre-wrap;
  background: #111;
  color: #0f0;
  padding: 10px;
  border-radius: 6px;
  min-height: 150px;
}
</style>
</head>

<body>

<h2>Edge Content Loader Tester</h2>

<label>URL:</label>
<input id="urlInput" value="https://fxmeet.github.io/cdn/media/images/tracking-pixels/14b_track.gif">

<label>Load type:</label>
<select id="typeSelect">
  <option value="img">img</option>
  <option value="iframe">iframe</option>
</select>

<label>Number of tries (max 32):</label>
<input id="triesInput" type="number" value="7" min="1" max="32">

<br>

<button id="runBtn">Run Test</button>
<button id="copyBtn">Copy Results</button>

<div id="results">Waiting...</div>

<script>
const runBtn = document.getElementById("runBtn");
const copyBtn = document.getElementById("copyBtn");
const out = document.getElementById("results");

let lastOutput = "";

function buildUrl(baseUrl) {
  const random = Math.floor(Math.random() * 1e10);
  return baseUrl + (baseUrl.includes("?") ? "&" : "?") + "nocache=" + random;
}

function loadResource(url, type) {
  return new Promise((resolve) => {
    const start = performance.now();
    const nocacheUrl = buildUrl(url);

    let el;
    let loadStart = 0;

    if (type === "img") {
      el = new Image();

      el.onload = () => {
        const end = performance.now();
        resolve({
          nocache: nocacheUrl,
          loadTime: end - loadStart,
          total: end - start
        });
      };

      el.onerror = () => {
        const end = performance.now();
        resolve({
          nocache: nocacheUrl,
          loadTime: -1,
          total: end - start
        });
      };

      loadStart = performance.now();
      el.src = nocacheUrl;
    }

    else if (type === "iframe") {
      el = document.createElement("iframe");

      el.onload = () => {
        const end = performance.now();
        resolve({
          nocache: nocacheUrl,
          loadTime: end - loadStart,
          total: end - start
        });
        document.body.removeChild(el);
      };

      el.onerror = () => {
        const end = performance.now();
        resolve({
          nocache: nocacheUrl,
          loadTime: -1,
          total: end - start
        });
        document.body.removeChild(el);
      };

      loadStart = performance.now();
      el.style.display = "none";
      el.src = nocacheUrl;
      document.body.appendChild(el);
    }
  });
}

runBtn.onclick = async function () {
  const baseUrl = document.getElementById("urlInput").value.trim();
  const type = document.getElementById("typeSelect").value;

  let tries = parseInt(document.getElementById("triesInput").value, 10);

  if (!baseUrl) {
    out.textContent = "Please enter URL.";
    return;
  }

  if (isNaN(tries) || tries < 1) tries = 1;
  if (tries > 32) tries = 32;

  out.textContent = `Running ${tries} tests (${type})...\n`;

  let results = [];

  for (let i = 0; i < tries; i++) {
    results.push(await loadResource(baseUrl, type));
  }

  let totalLoad = 0;
  let totalTime = 0;
  let valid = 0;

  let text = `RESULTS (${tries} TRIES | type=${type})\n\n`;

  results.forEach((r, i) => {
    text += `Run ${i + 1}:\n`;
    text += `  URL: ${r.nocache}\n`;

    if (r.loadTime < 0) {
      text += `  FAILED\n  Total: ${r.total.toFixed(2)} ms\n\n`;
    } else {
      text += `  Load time: ${r.loadTime.toFixed(2)} ms\n`;
      text += `  Total: ${r.total.toFixed(2)} ms\n\n`;

      totalLoad += r.loadTime;
      totalTime += r.total;
      valid++;
    }
  });

  if (valid > 0) {
    text += "AVERAGE:\n";
    text += `Load avg: ${(totalLoad / valid).toFixed(2)} ms\n`;
    text += `Total avg: ${(totalTime / valid).toFixed(2)} ms\n`;
  }

  lastOutput = text;
  out.textContent = text;
};

copyBtn.onclick = async function () {
  if (!lastOutput) return;

  await navigator.clipboard.writeText(lastOutput);
  out.textContent = "Copied results!\n\n" + lastOutput;
};
</script>

</body>
</html>
